@model N3DMMarket.Models.Db.User

@{
    ViewData["Title"] = "Edit User";
}

<h2>Edit User</h2>

<form asp-action="EditUserPost" method="post">
    <input type="hidden" name="userId" value="@Model.UserId" />
    <div>
        <label>Name</label>
        <input type="text" name="name" value="@Model.FullName" required />
    </div>
    <div>
        <label>Email</label>
        <input type="email" name="email" value="@Model.Email" />
    </div>
    <div>
    </div>
    <div>
        @Html.AntiForgeryToken()
        <button type="submit">Save</button>
        <a asp-action="Lab09_10">Cancel</a>
    </div>
</form>
