@{
    ViewData["Title"] = "Home";
    ViewData["ActivePage"] = "Home";
}

@* ── Hero ── *@
<section class="hero">
    <div class="container">
        <h1>Discover Premium<br /><span>3D Models</span> for Every Project</h1>
        <p>
            The marketplace for VTuber assets, 3D printing files, and creative workflow
            tools. Buy, sell, and collaborate with creators worldwide.
        </p>
        <div class="hero-actions">
            <a class="btn btn-primary btn-lg" href="@Url.Action("Index", "Store")">Browse Store</a>
            <a class="btn btn-secondary btn-lg" href="@Url.Action("Register", "Account")">Start Selling</a>
        </div>
    </div>
</section>

@* ── Categories ── *@
<section class="section">
    <div class="container">
        <div class="section-header">
            <h2>Browse by Category</h2>
            <a class="btn btn-ghost btn-sm" href="@Url.Action("Index", "Store")">View all</a>
        </div>

        <div class="category-grid">
            <a class="category-card" href="#">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2" />
                    <circle cx="12" cy="7" r="4" />
                </svg>
                <h3>VTuber Avatars</h3>
                <p>128 models</p>
            </a>

            <a class="category-card" href="#">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 002 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0022 16z" />
                </svg>
                <h3>3D Print Files</h3>
                <p>96 models</p>
            </a>

            <a class="category-card" href="#">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" />
                </svg>
                <h3>Props &amp; Accessories</h3>
                <p>74 models</p>
            </a>

            <a class="category-card" href="#">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="2" y="3" width="20" height="14" rx="2" ry="2" />
                    <line x1="8" y1="21" x2="16" y2="21" />
                    <line x1="12" y1="17" x2="12" y2="21" />
                </svg>
                <h3>Environments</h3>
                <p>52 models</p>
            </a>
        </div>
    </div>
</section>

@* ── Featured Models ── *@
<section class="section">
    <div class="container">
        <div class="section-header">
            <h2>Featured Models</h2>
            <a class="btn btn-ghost btn-sm" href="@Url.Action("Index", "Store")">View all</a>
        </div>

        <div class="product-grid">
            @* Card 1 *@
            <div class="product-card">
                <div class="product-thumb">
                    <span class="badge badge-primary product-badge">New</span>
                    3D Preview
                </div>
                <div class="product-info">
                    <h3>Sakura VTuber Avatar</h3>
                    <div class="product-meta">
                        <span class="product-price">$24.99</span>
                        <span class="product-seller">by ArtistPro</span>
                    </div>
                    <div class="product-tags">
                        <span class="tag">VTuber</span>
                        <span class="tag">Rigged</span>
                        <span class="tag">FBX</span>
                    </div>
                </div>
            </div>

            @* Card 2 *@
            <div class="product-card">
                <div class="product-thumb">
                    3D Preview
                </div>
                <div class="product-info">
                    <h3>Mechanical Dragon - Print Ready</h3>
                    <div class="product-meta">
                        <span class="product-price">$12.50</span>
                        <span class="product-seller">by MakerStudio</span>
                    </div>
                    <div class="product-tags">
                        <span class="tag">3D Print</span>
                        <span class="tag">STL</span>
                    </div>
                </div>
            </div>

            @* Card 3 *@
            <div class="product-card">
                <div class="product-thumb">
                    <span class="badge badge-warning product-badge">Popular</span>
                    3D Preview
                </div>
                <div class="product-info">
                    <h3>Cyberpunk Room Environment</h3>
                    <div class="product-meta">
                        <span class="product-price">$39.00</span>
                        <span class="product-seller">by SceneForge</span>
                    </div>
                    <div class="product-tags">
                        <span class="tag">Environment</span>
                        <span class="tag">Unity</span>
                        <span class="tag">GLTF</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
