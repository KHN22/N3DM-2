@model IEnumerable<N3DMMarket.Models.Db.User>

@{
    ViewData["Title"] = "Lab09-10 Sample Form";
}

<h2>Lab09-10 Sample Form</h2>

<form asp-action="CreateUser" method="post">
    <div>
        <label>Name</label>
        <input type="text" name="name" required />
    </div>
    <div>
        <label>Email</label>
        <input type="email" name="email" />
    </div>
    <div>
       
    </div>
    <div>
        <button type="submit">Submit</button>
    </div>
    @Html.AntiForgeryToken()
</form>

<h3>Saved Entries</h3>
<table border="1" cellpadding="6">
    <thead>
        <tr>
            <th>Id</th>
            <th>Name</th>
            <th>Email</th>
            <th>Created</th>
            <th>Action</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var e in Model)
    {
        <tr>
            <td>@e.UserId</td>
            <td>@e.FullName</td>
            <td>@e.Email</td>
            <td>@(e.CreatedDate?.ToString("g"))</td>
            <td>
                <a asp-action="EditUser" asp-route-id="@e.UserId">Edit</a>
                <form asp-action="DeleteUser" method="post" style="display:inline">
                    <input type="hidden" name="id" value="@e.UserId" />
                    @Html.AntiForgeryToken()
                    <button type="submit" onclick="return confirm('Delete this user?');">Delete</button>
                </form>
            </td>
        </tr>
    }
    </tbody>
</table>
