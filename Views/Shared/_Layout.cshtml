@* ── Main application layout (post-login) ── *@
@using N3DMMarket.Models.Db
@using Microsoft.EntityFrameworkCore
@using System.Linq
@using Marketplace.Lib
@using Marketplace.Models
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - 3DM</title>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
          rel="stylesheet" />

    <!-- Site Styles -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

@{
    // determine current user's role for UI decisions
    string currentRole = string.Empty;
    string profileImagePath = string.Empty;
    string avatarInitials = "U";
    try
    {
        var email = Context.Session.GetString("CurrentUserEmail");
        if (!string.IsNullOrEmpty(email))
        {
            var normalized = email.Trim().ToUpper();
            // resolve role via DbContext (safe if DbContext is available)
            try
            {
                var db = Context.RequestServices.GetService(typeof(N3DMMarket.Models.Db.ThreedmContext)) as N3DMMarket.Models.Db.ThreedmContext;
                if (db != null)
                {
                    var u = db.Users.Include(u => u.Role).FirstOrDefault(u => u.Email.ToUpper() == normalized);
                    currentRole = u?.Role?.RoleName ?? string.Empty;
                    profileImagePath = u?.ProfileImagePath ?? string.Empty;
                    
                    // Calculate initials
                    if (!string.IsNullOrEmpty(u?.FullName))
                    {
                        var parts = u.FullName.Split(' ', StringSplitOptions.RemoveEmptyEntries);
                        if (parts.Length == 1) 
                            avatarInitials = parts[0].Substring(0, Math.Min(2, parts[0].Length)).ToUpper();
                        else if (parts.Length > 1)
                            avatarInitials = ($"{parts[0][0]}{parts[parts.Length - 1][0]}").ToUpper();
                    }
                }
            }
            catch { /* ignore view-time DB errors */ }
        }
    }
    catch { }
}

    @* ── Navbar ── *@
    <nav class="navbar" role="navigation" aria-label="Main navigation">
        <div class="container-wide navbar-inner">

            @* Brand *@
            <a class="navbar-brand" href="@Url.Action("Index", "Home")">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 002 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0022 16z" />
                    <polyline points="3.27 6.96 12 12.01 20.73 6.96" />
                    <line x1="12" y1="22.08" x2="12" y2="12" />
                </svg>
                3DM
            </a>

            @* Center Nav *@
            <ul class="navbar-nav">
                <li>
                    <a class="nav-link @(ViewData["ActivePage"]?.ToString() == "Home" ? "active" : "")"
                       href="@Url.Action("Index", "Home")">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
                             fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z" />
                            <polyline points="9 22 9 12 15 12 15 22" />
                        </svg>
                        Home
                    </a>
                </li>
                <li>
                    <a class="nav-link @(ViewData["ActivePage"]?.ToString() == "Store" ? "active" : "")"
                       href="@Url.Action("Index", "Store")">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
                             fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="9" cy="21" r="1" /><circle cx="20" cy="21" r="1" />
                            <path d="M1 1h4l2.68 13.39a2 2 0 002 1.61h9.72a2 2 0 002-1.61L23 6H6" />
                        </svg>
                        Store
                    </a>
                </li>
                <li>
                    @{ var cart = Context.Session.GetObjectFromJson<List<CartItem>>("cart") ?? new List<CartItem>(); }
                    <a class="nav-link" href="@Url.Action("Cart", "Store")">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="9" cy="21" r="1" /><circle cx="20" cy="21" r="1" />
                            <path d="M1 1h4l2.68 13.39a2 2 0 002 1.61h9.72a2 2 0 002-1.61L23 6H6" />
                        </svg>
                        Cart (@cart.Sum(i => i.Quantity))
                    </a>
                </li>
            </ul>

            @* Right: profile / guest links *@
            @if (string.IsNullOrEmpty(Context.Session.GetString("CurrentUserEmail")))
            {
                <div class="navbar-right">
                    <a class="nav-link btn btn-ghost btn-sm" href="@Url.Action("Login", "Account")">Login</a>
                    <a class="nav-link btn btn-primary btn-sm" style="margin-left:8px;" href="@Url.Action("Register", "Account")">Register</a>
                </div>
            }
            else
            {
                <div class="navbar-right">
                    <div class="profile-dropdown">
                        <button class="profile-trigger" aria-haspopup="true" aria-expanded="false">
                            <div class="profile-avatar" id="navbarProfileAvatar">
                                @if (!string.IsNullOrEmpty(profileImagePath))
                                {
                                    <img src="@profileImagePath" alt="Profile" style="width: 100%; height: 100%; border-radius: 50%; object-fit: cover;" />
                                }
                                else
                                {
                                    @avatarInitials
                                }
                            </div>
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24"
                                 fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <polyline points="6 9 12 15 18 9" />
                            </svg>
                        </button>

                        <div class="profile-dropdown-menu" role="menu">
                            <a class="dropdown-item" href="@Url.Action("Index", "Profile")" role="menuitem">Profile</a>
                            <a class="dropdown-item" href="@Url.Action("History", "Profile")" role="menuitem">Purchase History</a>

                            @if (string.Equals(currentRole, "Seller", StringComparison.OrdinalIgnoreCase) || string.Equals(currentRole, "Admin", StringComparison.OrdinalIgnoreCase))
                            {
                                <a class="dropdown-item" href="@Url.Action("Index", "Seller")" role="menuitem">Seller Panel</a>
                            }

                            <div class="dropdown-divider"></div>

                            @if (string.Equals(currentRole, "Admin", StringComparison.OrdinalIgnoreCase) || string.Equals(currentRole, "Moderator", System.StringComparison.OrdinalIgnoreCase))
                            {
                                <a class="dropdown-item" href="@Url.Action("Index", "Admin")" role="menuitem">Admin Dashboard</a>
                            }

                            <a class="dropdown-item" href="@Url.Action("Settings", "Profile")" role="menuitem">Settings</a>

                            <div class="dropdown-divider"></div>

                            <a class="dropdown-item danger" href="@Url.Action("Logout", "Account")" role="menuitem">Logout</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    </nav>

    @* ── Page Content ── *@

    @{ var successMsg = TempData["Success"] as string; var errorMsg = TempData["Error"] as string; }
    @if (!string.IsNullOrEmpty(successMsg))
    {
        <div class="flash flash-success" role="status">@successMsg</div>
    }
    @if (!string.IsNullOrEmpty(errorMsg))
    {
        <div class="flash flash-error" role="alert">@errorMsg</div>
    }

    <main>
        @RenderBody()
    </main>

    @* ── Footer ── *@
    <footer class="site-footer">
        <div class="container-wide footer-inner">
            <p class="footer-copy">&copy; 2026 3DM. Built by Your Team.</p>
            <ul class="footer-links">
                <li><a href="#">About</a></li>
                <li><a href="#">Contact</a></li>
                <li><a href="#">Twitter</a></li>
                <li><a href="#">GitHub</a></li>
            </ul>
        </div>
    </footer>

    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        // Listen for profile image updates (broadcast between tabs/windows)
        if (typeof BroadcastChannel !== 'undefined') {
            const profileChannel = new BroadcastChannel('profile-updates');
            profileChannel.onmessage = function(event) {
                if (event.data.type === 'image-updated' && event.data.imagePath) {
                    updateNavbarAvatar(event.data.imagePath);
                }
            };
        }

        // Also check localStorage for updates
        window.addEventListener('storage', function(e) {
            if (e.key === 'profileImageUpdated') {
                const imagePath = localStorage.getItem('profileImagePath');
                if (imagePath) {
                    updateNavbarAvatar(imagePath);
                    localStorage.removeItem('profileImageUpdated');
                    localStorage.removeItem('profileImagePath');
                }
            }
        });

        function updateNavbarAvatar(imagePath) {
            const navAvatar = document.getElementById('navbarProfileAvatar');
            if (navAvatar) {
                navAvatar.innerHTML = `<img src="${imagePath}?t=${Date.now()}" alt="Profile" style="width: 100%; height: 100%; border-radius: 50%; object-fit: cover;" />`;
            }
        }

        // Expose function globally for profile page to call
        window.broadcastProfileImageUpdate = function(imagePath) {
            if (typeof BroadcastChannel !== 'undefined') {
                try {
                    const profileChannel = new BroadcastChannel('profile-updates');
                    profileChannel.postMessage({ type: 'image-updated', imagePath: imagePath });
                } catch (e) { }
            }
            // Also use localStorage as fallback
            localStorage.setItem('profileImagePath', imagePath);
            localStorage.setItem('profileImageUpdated', new Date().getTime());
        };
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
