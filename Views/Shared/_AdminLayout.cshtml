@* ── Admin layout: wraps page in sidebar + content area ── *@
@using N3DMMarket.Models.Db
@using Microsoft.EntityFrameworkCore
@inject ThreedmContext _db
@{
    Layout = "_Layout";

    var email = Context.Session.GetString("CurrentUserEmail");
    var currentRole = string.Empty;
    if (!string.IsNullOrEmpty(email))
    {
        var normalized = email.Trim().ToUpper();
        var user = _db.Users.Include(u => u.Role).FirstOrDefault(u => u.Email.ToUpper() == normalized);
        currentRole = user?.Role?.RoleName ?? string.Empty;
    }
}

<div class="admin-layout">
    @* ── Sidebar ── *@
    <aside class="admin-sidebar" role="navigation" aria-label="Admin navigation">
        <span class="sidebar-title">Administration</span>

        <a href="@Url.Action("Index", "Admin")"
           class="@(ViewData["AdminPage"]?.ToString() == "Overview" ? "active" : "")">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                 stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="3" width="7" height="7" /><rect x="14" y="3" width="7" height="7" />
                <rect x="3" y="14" width="7" height="7" /><rect x="14" y="14" width="7" height="7" />
            </svg>
            Overview
        </a>

        <a href="@Url.Action("Users", "Admin")"
           class="@(ViewData["AdminPage"]?.ToString() == "Users" ? "active" : "")">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                 stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2" />
                <circle cx="9" cy="7" r="4" />
                <path d="M23 21v-2a4 4 0 00-3-3.87" /><path d="M16 3.13a4 4 0 010 7.75" />
            </svg>
            User Management
        </a>

        <a href="@Url.Action("SellerApprovals", "Admin")"
           class="@(ViewData["AdminPage"]?.ToString() == "Sellers" ? "active" : "")">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                 stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M16 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2" />
                <circle cx="8.5" cy="7" r="4" />
                <polyline points="17 11 19 13 23 9" />
            </svg>
            Seller Approvals
        </a>

        <a href="@Url.Action("Sales", "Admin")"
           class="@(ViewData["AdminPage"]?.ToString() == "Sales" ? "active" : "")">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                 stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="12" y1="1" x2="12" y2="23" /><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6" />
            </svg>
            Sales Overview
        </a>

        <a href="@Url.Action("Promotions", "Admin")"
           class="@(ViewData["AdminPage"]?.ToString() == "Promotions" ? "active" : "")">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                 stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M3 3h18v6H3z" />
                <path d="M3 13h18v8H3z" />
            </svg>
            Promotions
        </a>

        <a href="@Url.Action("Products", "Admin")"
           class="@(ViewData["AdminPage"]?.ToString() == "Products" ? "active" : "")">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                 stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="9" cy="21" r="1" />
                <circle cx="20" cy="21" r="1" />
                <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6" />
            </svg>
            Product Management
        </a>

        @if (string.Equals(currentRole, "Admin", System.StringComparison.OrdinalIgnoreCase))
        {
            <a href="@Url.Action("Roles", "Admin")"
               class="@(ViewData["AdminPage"]?.ToString() == "Roles" ? "active" : "")">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                 stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
            </svg>
            Role Management
            </a>
        }
    </aside>

    @* ── Content ── *@
    <div class="admin-content">
        @RenderBody()
    </div>
</div>
