@model List<SellerApprovalRow>
@{
    ViewData["Title"] = "Seller Approvals";
    ViewData["ActivePage"] = "Admin";
    ViewData["AdminPage"] = "Sellers";
    Layout = "_AdminLayout";
}

<h1>Seller Approval Queue</h1>
<p class="page-desc">Review and approve pending seller applications</p>

@* ── Quick Stats ── *@
<div class="stats-grid" style="grid-template-columns:repeat(3,1fr); margin-bottom:28px;">
    <div class="stat-card">
        <span class="stat-label">Pending (All-time)</span>
        <span class="stat-value" style="color:var(--accent-warning);">@((ViewBag.PendingCount ?? 0))</span>
    </div>
    <div class="stat-card">
        <span class="stat-label">Approved (All-time)</span>
        <span class="stat-value" style="color:var(--accent-success);">@((ViewBag.ApprovedCount ?? 0))</span>
    </div>
    <div class="stat-card">
        <span class="stat-label">Rejected (All-time)</span>
        <span class="stat-value" style="color:var(--accent-danger);">@((ViewBag.RejectedCount ?? 0))</span>
    </div>
</div>

@* ── Approvals Table ── *@
<div class="card">
    <div class="table-wrapper">
        <table class="data-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Applicant</th>
                    <th>Email</th>
                    <th>Applied</th>
                    <th>Status</th>
                    <th style="text-align:right;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Count > 0)
                {
                    @foreach (var seller in Model)
                    {
                        <tr>
                            <td style="font-family:var(--font-mono); font-size:0.8125rem;">#@seller.Id</td>
                            <td style="color:var(--text-primary); font-weight:500;">@seller.FullName</td>
                            <td>@seller.Email</td>
                            <td>@seller.AppliedDate.ToString("MMM dd, yyyy")</td>
                            <td>
                                @if (seller.Status == "Pending")
                                {
                                    <span class="badge badge-warning">Pending</span>
                                }
                                else if (seller.Status == "Approved")
                                {
                                    <span class="badge badge-success">Approved</span>
                                }
                                else
                                {
                                    <span class="badge badge-danger">Rejected</span>
                                }
                            </td>
                            <td style="text-align:right; display:flex; gap:6px; justify-content:flex-end;">
                                @if (seller.Status == "Pending")
                                {
                                    <form method="post" asp-action="ApproveSeller" style="display:inline-block; margin:0;">
                                        <input type="hidden" name="userId" value="@seller.Id" />
                                        <button class="btn btn-success btn-sm">Approve</button>
                                    </form>
                                    <form method="post" asp-action="RejectSeller" style="display:inline-block; margin:0; margin-left:6px;">
                                        <input type="hidden" name="userId" value="@seller.Id" />
                                        <button class="btn btn-danger btn-sm">Reject</button>
                                    </form>
                                }
                                else
                                {
                                    <span style="font-size:0.8125rem; color:var(--text-muted);">--</span>
                                }
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6">No pending seller applications.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
