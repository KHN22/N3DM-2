@model N3DMMarket.Models.Db.Promotion
@{
    ViewData["Title"] = "Edit Promotion";
    ViewData["ActivePage"] = "Admin";
    ViewData["AdminPage"] = "Promotions";
    Layout = "_AdminLayout";
}

<h1>Edit Promotion</h1>

<form method="post" asp-action="EditPromotion">
    @Html.AntiForgeryToken()
    @Html.ValidationSummary(true, "", new { @class = "validation-summary" })
    <input type="hidden" name="Id" value="@Model.Id" />
    <div class="form-row">
        <label>Name</label>
        <input name="Name" class="form-input" value="@Model.Name" />
    </div>
    <div class="form-row">
        <label>Code (optional)</label>
        <input name="Code" class="form-input" value="@Model.Code" />
    </div>
    <div class="form-row">
        <label>Type</label>
        <select name="Type" class="form-select">
            <option value="0">Percentage</option>
            <option value="1">FixedAmount</option>
            <option value="2">FreeShipping</option>
            <option value="3">BOGO</option>
        </select>
    </div>
    <div class="form-row">
        <label>Max Uses (total)</label>
        <input name="MaxUses" type="number" min="0" class="form-input" value="@(Model.MaxUses?.ToString() ?? string.Empty)" />
    </div>
    <div class="form-row">
        <label>Max Uses Per User</label>
        <input name="MaxUsesPerUser" type="number" min="0" class="form-input" value="@(Model.MaxUsesPerUser?.ToString() ?? string.Empty)" />
    </div>
    <div class="form-row">
        <label>Applies To</label>
        <select name="AppliesTo" class="form-select">
            <option value="All">All</option>
            <option value="Product">Product</option>
            <option value="Category">Category</option>
        </select>
    </div>
    <div class="form-row">
        <label>Value</label>
        <input name="Value" type="number" step="0.01" class="form-input" value="@Model.Value" />
    </div>
    <div class="form-row">
        <label>Min Order Amount</label>
        <input name="MinOrderAmount" type="number" step="0.01" class="form-input" value="@Model.MinOrderAmount" />
    </div>
    <div class="form-row">
        <label>Start Date</label>
        <input name="StartDate" type="date" class="form-input" value="@(Model.StartDate?.ToString("yyyy-MM-dd") ?? string.Empty)" />
    </div>
    <div class="form-row">
        <label>End Date</label>
        <input name="EndDate" type="date" class="form-input" value="@(Model.EndDate?.ToString("yyyy-MM-dd") ?? string.Empty)" />
    </div>
    <div class="form-row">
        <label>Metadata (JSON)</label>
        <textarea name="Metadata" class="form-input" rows="3">@Model.Metadata</textarea>
    </div>
    <div class="form-row">
        <label>Active</label>
        <input type="hidden" name="IsActive" value="false" />
        <input type="checkbox" name="IsActive" value="true" @(Model.IsActive ? "checked" : "") />
    </div>
    <div style="margin-top:12px;">
        <button class="btn btn-primary" type="submit">Save</button>
        <a class="btn btn-ghost" href="@Url.Action("Promotions","Admin")">Cancel</a>
    </div>
</form>

<script>
    (function(){
        var sel = document.querySelector('select[name="Type"]');
        if (sel) sel.value = '@((int)Model.Type)';
    })();
</script>
