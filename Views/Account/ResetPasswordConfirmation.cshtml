
@{
    ViewData["Title"] = "Password Reset";
    Layout = "_AuthLayout";
}

<div class="auth-wrapper">
    <div class="auth-card">
        <div class="auth-brand">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                 stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 002 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0022 16z" />
                <polyline points="3.27 6.96 12 12.01 20.73 6.96" />
                <line x1="12" y1="22.08" x2="12" y2="12" />
            </svg>
            ModelVault
        </div>

        <h1>Password reset</h1>
        <p class="auth-subtitle">Your password has been updated. You can now <a asp-controller="Account" asp-action="Login">sign in</a> with your new password.</p>

        <p class="auth-footer">Return to <a asp-action="Login" asp-controller="Account">Sign in</a></p>
    </div>
</div>
