@model Marketplace.Models.Order

@{
    ViewData["Title"] = "Payment";
}

<div class="container page-payment" style="padding-top:28px;">
    <h1>Payment</h1>

    <p>Order: <strong>@Model.Id</strong></p>
    @{
        var promoAmount = ViewBag.AppliedPromotionAmount as decimal? ?? 0m;
        var displayTotal = Model.Total - promoAmount;
    }
    <p>Total: <strong>@displayTotal.ToString("C")</strong>
        @if (promoAmount > 0)
        {
            <span style="color:green;">(saved @promoAmount.ToString("C"))</span>
        }
    </p>

    @if (TempData["PromoError"] != null)
    {
        <div class="alert alert-danger">@TempData["PromoError"]</div>
    }

    <form method="post" action="@Url.Action("ApplyPromotionByCode","Store")" style="background:var(--bg-card); border:1px solid var(--border-color); border-radius:10px; padding:20px; margin-bottom:24px;">
        <input type="hidden" name="orderId" value="@Model.Id" />
        <h3 style="margin-top:0; margin-bottom:12px; font-size:1rem;">Have a Promo Code?</h3>
        <div style="display:flex; gap:8px; align-items:center;">
            <input name="code" placeholder="Enter promo code" style="flex:1; max-width:280px; padding:10px 12px; border:1px solid var(--border-color); border-radius:6px; background:var(--bg-input); color:var(--text-primary); font-size:0.875rem;" />
            <button class="btn btn-primary" type="submit">Apply Code</button>
        </div>
    </form>

    <div style="margin-bottom:24px;">
        <button id="show-promos-btn" class="btn btn-outline" style="width:100%; justify-content:center;">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right:6px;">
                <path d="M21.5 2v6h-6M2.5 22v-6h6M2 11.5a10 10 0 0 1 18.8-4.3M22 12.5a10 10 0 0 1-18.8 4.2"/>
            </svg>
            View Available Promotions
        </button>
    </div>

    <div id="available-promos-container" style="margin-bottom:24px; display:none;">
        <div id="available-promos"></div>
    </div>

    <h3 style="margin-bottom:16px;">Complete Payment</h3>

    <div style="display:grid; grid-template-columns: 1fr 1fr; gap:24px; align-items:start;">
        <div style="background:var(--bg-card); border:1px solid var(--border-color); border-radius:10px; padding:24px; display:flex; flex-direction:column; align-items:center; justify-content:center;">
            <p style="font-size:0.75rem; color:var(--text-muted); text-transform:uppercase; letter-spacing:0.05em; margin-bottom:12px; margin-top:0;">Scan to Pay</p>
            <div class="component-qr-mock" style="width:200px; height:200px; display:flex; align-items:center; justify-content:center; background:var(--bg-secondary); border-radius:8px;">
                <svg width="160" height="160" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
                    <rect x="0" y="0" width="100" height="100" fill="var(--bg-secondary)" />
                    <rect x="5" y="5" width="20" height="20" fill="var(--text-primary)" />
                    <rect x="75" y="5" width="20" height="20" fill="var(--text-primary)" />
                    <rect x="5" y="75" width="20" height="20" fill="var(--text-primary)" />
                    <rect x="40" y="40" width="8" height="8" fill="var(--text-primary)" />
                    <rect x="52" y="40" width="8" height="8" fill="var(--text-primary)" />
                    <rect x="40" y="52" width="8" height="8" fill="var(--text-primary)" />
                    <rect x="52" y="52" width="8" height="8" fill="var(--text-primary)" />
                </svg>
            </div>
            <p style="font-size:0.8125rem; color:var(--text-muted); margin-top:12px; margin-bottom:0; text-align:center;">Prototype QR code — scanning would process payment on a real device</p>
        </div>

        <div>
            <div style="background:var(--bg-card); border:1px solid var(--border-color); border-radius:10px; padding:20px; margin-bottom:16px;">
                <h4 style="margin-top:0; margin-bottom:12px; font-size:0.9375rem;">Order Summary</h4>
                <div style="font-size:0.875rem; color:var(--text-muted); margin-bottom:12px;">
                    <div style="display:flex; justify-content:space-between; margin-bottom:8px;">
                        <span>Order ID:</span>
                        <span style="font-family:var(--font-mono); color:var(--text-primary); font-weight:600;">@Model.Id</span>
                    </div>
                    <div style="display:flex; justify-content:space-between; padding-top:8px; border-top:1px solid var(--border-color); margin-top:8px;">
                        <span style="font-weight:600; color:var(--text-primary);">Total Amount:</span>
                        <span style="font-weight:700; color:var(--accent-success); font-size:1.125rem;">@displayTotal.ToString("C")</span>
                    </div>
                    @if (promoAmount > 0)
                    {
                        <div style="display:flex; justify-content:space-between; color:var(--accent-success); margin-top:8px;">
                            <span>Savings:</span>
                            <span style="font-weight:600;">@promoAmount.ToString("C")</span>
                        </div>
                    }
                </div>
            </div>

            <form method="post" action="@Url.Action("PaymentProcess", "Store")">
                <input type="hidden" name="id" value="@Model.Id" />
                <button class="btn btn-primary" type="submit" style="width:100%; justify-content:center;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right:6px;">
                        <circle cx="12" cy="12" r="1"/>
                        <path d="M12 1v6m0 6v6M4.22 4.22l4.24 4.24m2.12 2.12l4.24 4.24M1 12h6m6 0h6m-17.78 7.78l4.24-4.24m2.12-2.12l4.24-4.24"/>
                    </svg>
                    Confirm Payment (Simulate)
                </button>
            </form>
        </div>
    </div>
</div>

<script>
    (function(){
        var btn = document.getElementById('show-promos-btn');
        var container = document.getElementById('available-promos-container');
        var inner = document.getElementById('available-promos');
        if(!btn) return;
        btn.addEventListener('click', function(){
            if(container.style.display === 'none'){
                fetch('@Url.Action("AvailablePromotions","Store")?orderId=' + encodeURIComponent('@Model.Id'))
                    .then(function(r){ return r.text(); })
                    .then(function(html){ inner.innerHTML = html; container.style.display = 'block'; btn.textContent = 'Hide promotions'; })
                    .catch(function(){ inner.innerHTML = '<div>Error loading promotions</div>'; container.style.display = 'block'; });
            } else {
                container.style.display = 'none';
                btn.textContent = 'View available promotions';
            }
        });
    })();
</script>
