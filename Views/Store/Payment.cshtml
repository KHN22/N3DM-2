@model Marketplace.Models.Order

@{
    ViewData["Title"] = "Payment";
}

<div class="container" style="padding-top:28px;">
    <h1>Payment</h1>

    <p>Order: <strong>@Model.Id</strong></p>
    <p>Total: <strong>@Model.Total.ToString("C")</strong></p>

    <h3>Scan to pay (mock)</h3>

    <div style="display:flex;gap:20px;align-items:center">
        <div style="width:220px;height:220px;border:1px solid #ccc;display:flex;align-items:center;justify-content:center;background:#f7f7f7">
            @* Simple QR-like placeholder *@
            <svg width="160" height="160" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
                <rect x="0" y="0" width="100" height="100" fill="#fff" />
                <rect x="5" y="5" width="20" height="20" fill="#111" />
                <rect x="75" y="5" width="20" height="20" fill="#111" />
                <rect x="5" y="75" width="20" height="20" fill="#111" />
                <rect x="40" y="40" width="8" height="8" fill="#111" />
                <rect x="52" y="40" width="8" height="8" fill="#111" />
                <rect x="40" y="52" width="8" height="8" fill="#111" />
                <rect x="52" y="52" width="8" height="8" fill="#111" />
            </svg>
        </div>

        <div>
            <p>This is a prototype QR mock. After scanning on a real device the payment would be processed.</p>
            <form method="post" action="@Url.Action("PaymentProcess", "Store")">
                <input type="hidden" name="id" value="@Model.Id" />
                <button class="btn primary" type="submit">I have paid (simulate)</button>
            </form>
        </div>
    </div>
</div>
