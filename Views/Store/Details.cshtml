@model Marketplace.Models.ProductViewModel

@{
    ViewData["Title"] = Model.Title;
}

<div class="container page-product-detail" style="padding-top:28px;">
    <div class="product-detail">
        <div style="float:left; margin-right:16px;">
            <img src="@Model.ThumbnailUrl" alt="@Model.Title" style="width:320px;height:240px;object-fit:cover;" />
        </div>
        <div class="product-detail-info">
            <h1>@Model.Title</h1>
            <p class="text-muted">by @Model.Seller</p>
            <p class="product-price" style="font-size:1.25rem; font-weight:700;">$@Model.Price.ToString("F2")</p>
            <p class="product-category">Category: @Model.Category</p>
            <div class="product-tags">
                @foreach(var t in Model.Tags) { <span class="tag">@t</span> }
            </div>

            <div style="margin-top:18px; display:flex; gap:8px; align-items:center;">
                <form method="post" action="@Url.Action("AddToCart", "Store")">
                    <input type="hidden" name="id" value="@Model.Id" />
                    <button class="btn">Add to Cart</button>
                </form>

                <a class="btn" href="/Store">Back to Store</a>
            </div>
        </div>
    </div>
</div>
