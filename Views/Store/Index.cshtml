@model List<Marketplace.Models.ProductViewModel>

@{
    ViewData["Title"] = "Store";
    ViewData["ActivePage"] = "Store";
}

<div class="container" style="padding-top:32px; padding-bottom:60px;">

    <h1 style="font-size:1.5rem; font-weight:700; margin-bottom:4px;">Store</h1>
    <p class="text-muted" style="margin-bottom:24px;">Browse 3D models from talented creators</p>

    <div class="store-toolbar">
        <div class="search-box">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                 stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="11" cy="11" r="8" /><line x1="21" y1="21" x2="16.65" y2="16.65" />
            </svg>
            <input class="form-input" type="text" placeholder="Search models..." />
        </div>
    </div>

    <div class="product-grid">

        @if (Model != null && Model.Count > 0)
        {
            @foreach (var product in Model)
            {
                <div class="product-card">
                    <a class="product-thumb-link" href="/Store/Details/@product.Id">
                        <div class="product-thumb">
                            @if (product.IsNew)
                            {
                                <span class="badge badge-primary product-badge">New</span>
                            }
                            3D Preview
                        </div>
                    </a>
                    <div class="product-info">
                        <h3><a href="/Store/Details/@product.Id">@product.Title</a></h3>
                        <div class="product-meta">
                            <span class="product-price">$@product.Price.ToString("F2")</span>
                            <span class="product-seller">by @product.Seller</span>
                        </div>
                        <div class="product-tags">
                            @foreach (var tag in product.Tags)
                            {
                                <span class="tag">@tag</span>
                            }
                        </div>
                        <div style="margin-top:8px;">
                            <form method="post" action="@Url.Action("AddToCart", "Store")" style="display:inline">
                                <input type="hidden" name="id" value="@product.Id" />
                                <button class="btn" type="submit">Add to cart</button>
                            </form>
                            <a class="btn" href="/Store/Details/@product.Id">View</a>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <p>No products available.</p>
        }
    </div>
</div>
