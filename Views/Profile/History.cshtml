@model List<PurchaseViewModel>
@{
    ViewData["Title"] = "Purchase History";
    ViewData["ActivePage"] = "Profile";
}

<div class="container" style="padding-top:32px; padding-bottom:60px;">

    <h1 style="font-size:1.5rem; font-weight:700; margin-bottom:4px;">Purchase History</h1>
    <p class="text-muted" style="margin-bottom:24px;">View all your past orders and downloads</p>

    <div class="card">
        <div class="table-wrapper">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Order ID</th>
                        <th>Product</th>
                        <th>Seller</th>
                        <th>Amount</th>
                        <th>Date</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Count > 0)
                    {
                        @foreach (var purchase in Model)
                        {
                            <tr>
                                <td style="font-family:var(--font-mono); font-size:0.8125rem;">@purchase.OrderId</td>
                                <td style="color:var(--text-primary); font-weight:500;">@purchase.ProductTitle</td>
                                <td>@purchase.Seller</td>
                                <td style="font-weight:600; color:var(--text-primary);">$@purchase.Amount.ToString("F2")</td>
                                <td>@purchase.PurchaseDate.ToString("MMM dd, yyyy")</td>
                                <td>
                                    @if (purchase.Status == "Completed")
                                    {
                                        <span class="badge badge-success">Completed</span>
                                    }
                                    else if (purchase.Status == "Pending")
                                    {
                                        <span class="badge badge-warning">Pending</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-danger">Refunded</span>
                                    }
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        @* Static mock rows *@
                        <tr>
                            <td style="font-family:var(--font-mono); font-size:0.8125rem;">#ORD-4821</td>
                            <td style="color:var(--text-primary); font-weight:500;">Sakura VTuber Avatar</td>
                            <td>ArtistPro</td>
                            <td style="font-weight:600; color:var(--text-primary);">$24.99</td>
                            <td>Jan 15, 2026</td>
                            <td><span class="badge badge-success">Completed</span></td>
                        </tr>
                        <tr>
                            <td style="font-family:var(--font-mono); font-size:0.8125rem;">#ORD-4790</td>
                            <td style="color:var(--text-primary); font-weight:500;">Mechanical Dragon</td>
                            <td>MakerStudio</td>
                            <td style="font-weight:600; color:var(--text-primary);">$12.50</td>
                            <td>Jan 10, 2026</td>
                            <td><span class="badge badge-success">Completed</span></td>
                        </tr>
                        <tr>
                            <td style="font-family:var(--font-mono); font-size:0.8125rem;">#ORD-4755</td>
                            <td style="color:var(--text-primary); font-weight:500;">Cyberpunk Room</td>
                            <td>SceneForge</td>
                            <td style="font-weight:600; color:var(--text-primary);">$39.00</td>
                            <td>Dec 28, 2025</td>
                            <td><span class="badge badge-warning">Pending</span></td>
                        </tr>
                        <tr>
                            <td style="font-family:var(--font-mono); font-size:0.8125rem;">#ORD-4710</td>
                            <td style="color:var(--text-primary); font-weight:500;">Low-Poly Fox</td>
                            <td>PolyWorks</td>
                            <td style="font-weight:600; color:var(--text-primary);">$8.00</td>
                            <td>Dec 20, 2025</td>
                            <td><span class="badge badge-danger">Refunded</span></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
