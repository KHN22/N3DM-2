@model ProfileViewModel
@{
    ViewData["Title"] = "Profile";
    ViewData["ActivePage"] = "Profile";
}

<div class="container page-profile">

    @* ── Profile Header ── *@
    <div class="profile-header-section">
        <div class="profile-avatar-lg" id="profileAvatarDisplay" style="cursor: pointer; position: relative;" title="Click to upload image">
            @if (!string.IsNullOrEmpty(Model?.ProfileImagePath))
            {
                <img src="@Model.ProfileImagePath" alt="Profile" style="width: 100%; height: 100%; border-radius: 12px; object-fit: cover;" />
            }
            else
            {
                <span>@(Model?.AvatarInitials ?? "JD")</span>
            }
            <div style="position: absolute; bottom: 0; right: 0; background: var(--accent-primary); border-radius: 50%; width: 32px; height: 32px; display: flex; align-items: center; justify-content: center; cursor: pointer;">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M23 19a2 2 0 01-2 2H3a2 2 0 01-2-2V8a2 2 0 012-2h4l2-3h6l2 3h4a2 2 0 012 2z" />
                    <circle cx="12" cy="13" r="4" />
                </svg>
            </div>
        </div>
        <input type="file" id="profileImageInput" name="ProfileImage" accept="image/*" style="display: none;" />
        <div class="profile-details">
            <h1>@(Model?.FullName ?? "Jane Doe")</h1>
            <p>@(Model?.Email ?? "jane@example.com")</p>
            <div class="profile-badges">
                <span class="badge badge-primary">@(Model?.Role ?? "Buyer")</span>

                @if (Model?.SellerStatus == "Pending")
                {
                    <span class="badge badge-warning">Seller Pending</span>
                }
                else if (Model?.SellerStatus == "Approved")
                {
                    <span class="badge badge-success">Seller Approved</span>
                }
            </div>
        </div>
    </div>

    @* ── Settings Grid ── *@
    <div class="settings-grid">

        @* Sidebar Nav *@
        <nav class="settings-nav" aria-label="Profile navigation">
            <a href="@Url.Action("Index", "Profile")" class="active">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2" /><circle cx="12" cy="7" r="4" />
                </svg>
                General
            </a>
            <a href="@Url.Action("Settings", "Profile")">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="3" />
                    <path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4" />
                </svg>
                Settings
            </a>
            <a href="@Url.Action("History", "Profile")">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="2" y="3" width="20" height="14" rx="2" ry="2" />
                    <line x1="8" y1="21" x2="16" y2="21" /><line x1="12" y1="17" x2="12" y2="21" />
                </svg>
                Purchase History
            </a>
        </nav>

        @* Main Panel *@
        <div class="settings-panel">
            <h2>General Information</h2>
            <p class="settings-desc">Update your personal details and public profile</p>

            <form class="settings-form" asp-action="Index" asp-controller="Profile" method="post">
                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label" for="profileName">Full Name</label>
                        <input class="form-input" type="text" id="profileName" name="FullName"
                               value="@(Model?.FullName ?? "Jane Doe")" />
                    </div>
                    <div class="form-group">
                        <label class="form-label" for="profileEmail">Email</label>
                        <input class="form-input" type="email" id="profileEmail" name="Email"
                               value="@(Model?.Email ?? "jane@example.com")" />
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label" for="profileBio">Bio</label>
                    <textarea class="form-textarea" id="profileBio" name="Bio"
                              placeholder="Tell us about yourself...">@(Model?.Bio ?? "")</textarea>
                </div>

                <div style="display:flex; justify-content:flex-end; gap:8px; margin-top:8px;">
                    <button class="btn btn-secondary" type="button">Cancel</button>
                    <button class="btn btn-primary" type="submit">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const profileAvatar = document.getElementById('profileAvatarDisplay');
        const fileInput = document.getElementById('profileImageInput');

        // Click avatar to upload image
        profileAvatar.addEventListener('click', function() {
            fileInput.click();
        });

        // Handle file selection
        fileInput.addEventListener('change', function() {
            if (this.files.length > 0) {
                uploadProfileImage(this.files[0]);
            }
        });

        function uploadProfileImage(file) {
            const formData = new FormData();
            formData.append('image', file);

            // Show loading state
            profileAvatar.style.opacity = '0.5';

            fetch('@Url.Action("UploadImage", "Profile")', {
                method: 'POST',
                body: formData
            })
            .then(response => response.json())
            .then(data => {
                profileAvatar.style.opacity = '1';
                if (data.success) {
                    // Update the avatar display
                    profileAvatar.innerHTML = `<img src="${data.imagePath}?t=${Date.now()}" alt="Profile" style="width: 100%; height: 100%; border-radius: 12px; object-fit: cover;" />
                        <div style="position: absolute; bottom: 0; right: 0; background: var(--accent-primary); border-radius: 50%; width: 32px; height: 32px; display: flex; align-items: center; justify-content: center; cursor: pointer;">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M23 19a2 2 0 01-2 2H3a2 2 0 01-2-2V8a2 2 0 012-2h4l2-3h6l2 3h4a2 2 0 012 2z" />
                                <circle cx="12" cy="13" r="4" />
                            </svg>
                        </div>`;
                    
                    // Broadcast the update to navbar
                    if (window.broadcastProfileImageUpdate) {
                        window.broadcastProfileImageUpdate(data.imagePath);
                    }
                    
                    // Show success message
                    setTimeout(() => {
                        if (window.location.href.includes('#')) {
                            window.location.hash = 'success';
                        }
                    }, 500);
                } else {
                    alert('Error uploading image: ' + (data.error || 'Unknown error'));
                }
            })
            .catch(error => {
                profileAvatar.style.opacity = '1';
                alert('Error uploading image: ' + error.message);
            });
        }
    });
</script>
