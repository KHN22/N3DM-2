@model Marketplace.Models.SellerSettingsViewModel
@{
    ViewData["Title"] = "Store Settings";
    ViewData["SellerPage"] = "Settings";
    Layout = "_SellerLayout";

    // Mock data for static preview
    var settings = Model ?? new Marketplace.Models.SellerSettingsViewModel
    {
        StoreName = "Creative 3D Studio",
        StoreDescription = "High-quality 3D models and assets for game developers and visual artists.",
        ContactEmail = "contact@creative3dstudio.com",
        PayoutMethod = "PayPal",
        PaypalEmail = "seller@email.com",
        EmailNotifications = true,
        OrderNotifications = true,
        ReviewNotifications = true
    };
}

<div class="seller-settings-page">
    @* ── Page Header ── *@
    <div class="page-header-flex">
        <div>
            <h1>Store Settings</h1>
            <p class="page-desc">Manage your store profile, payout settings, and notifications.</p>
        </div>
    </div>

    <div class="settings-layout">
        @* ── Settings Navigation ── *@
        <nav class="settings-nav-vertical">
            <a href="#store-profile" class="settings-nav-item active">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/>
                    <polyline points="9 22 9 12 15 12 15 22"/>
                </svg>
                Store Profile
            </a>
            <a href="#payout-settings" class="settings-nav-item">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="1" y="4" width="22" height="16" rx="2" ry="2"/>
                    <line x1="1" y1="10" x2="23" y2="10"/>
                </svg>
                Payout Settings
            </a>
            <a href="#notifications" class="settings-nav-item">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9"/>
                    <path d="M13.73 21a2 2 0 01-3.46 0"/>
                </svg>
                Notifications
            </a>
            <a href="#api-access" class="settings-nav-item">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="16 18 22 12 16 6"/>
                    <polyline points="8 6 2 12 8 18"/>
                </svg>
                API Access
            </a>
        </nav>

        @* ── Settings Content ── *@
        <div class="settings-content">
            @* Store Profile Section *@
            <section id="store-profile" class="settings-section card">
                <div class="settings-section-header">
                    <h2>Store Profile</h2>
                    <p>This information will be displayed publicly on your seller profile.</p>
                </div>
                <form class="settings-form" asp-action="UpdateStoreProfile" method="post">
                    <div class="form-group">
                        <label class="form-label" for="storeName">Store Name</label>
                        <input type="text" id="storeName" name="StoreName" class="form-input" value="@settings.StoreName" />
                        <span class="form-hint">This is how your store appears to buyers.</span>
                    </div>

                    <div class="form-group">
                        <label class="form-label" for="storeDesc">Store Description</label>
                        <textarea id="storeDesc" name="StoreDescription" class="form-textarea" rows="4">@settings.StoreDescription</textarea>
                        <span class="form-hint">Describe what you sell and your expertise. Max 500 characters.</span>
                    </div>

                    <div class="form-group">
                        <label class="form-label">Store Logo</label>
                        <div class="logo-upload-area">
                            <div class="current-logo">
                                <div class="logo-placeholder">
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                                         stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/>
                                    </svg>
                                </div>
                                <div class="logo-actions">
                                    <button type="button" class="btn btn-secondary btn-sm">Upload Logo</button>
                                    <span class="form-hint">PNG, JPG. Recommended 200x200px.</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="form-label" for="contactEmail">Contact Email</label>
                        <input type="email" id="contactEmail" name="ContactEmail" class="form-input" value="@settings.ContactEmail" />
                        <span class="form-hint">Buyers can reach you at this email for support inquiries.</span>
                    </div>

                    <div class="form-group">
                        <label class="form-label">Social Links</label>
                        <div class="social-links-grid">
                            <div class="social-input">
                                <span class="social-prefix">
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="16" height="16">
                                        <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                                    </svg>
                                </span>
                                <input type="text" class="form-input" placeholder="username" />
                            </div>
                            <div class="social-input">
                                <span class="social-prefix">
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="16" height="16">
                                        <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
                                    </svg>
                                </span>
                                <input type="text" class="form-input" placeholder="username" />
                            </div>
                            <div class="social-input">
                                <span class="social-prefix">
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="16" height="16">
                                        <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                                    </svg>
                                </span>
                                <input type="text" class="form-input" placeholder="username" />
                            </div>
                        </div>
                    </div>

                    <div class="form-actions">
                        <button type="submit" class="btn btn-primary">Save Changes</button>
                    </div>
                </form>
            </section>

            @* Payout Settings Section *@
            <section id="payout-settings" class="settings-section card">
                <div class="settings-section-header">
                    <h2>Payout Settings</h2>
                    <p>Configure how you receive your earnings.</p>
                </div>
                <form class="settings-form" asp-action="UpdatePayoutSettings" method="post">
                    <div class="form-group">
                        <label class="form-label">Payout Method</label>
                        <div class="payout-method-options">
                            <label class="payout-method-option @(settings.PayoutMethod == "PayPal" ? "selected" : "")">
                                <input type="radio" name="PayoutMethod" value="PayPal" @(settings.PayoutMethod == "PayPal" ? "checked" : "") />
                                <div class="method-card">
                                    <div class="method-icon paypal">
                                        <svg viewBox="0 0 24 24" fill="currentColor">
                                            <path d="M7.076 21.337H2.47a.641.641 0 01-.633-.74L4.944.901C5.026.382 5.474 0 5.998 0h7.46c2.57 0 4.578.543 5.69 1.81 1.01 1.15 1.304 2.42 1.012 4.287-.023.143-.047.288-.077.437-.983 5.05-4.349 6.797-8.647 6.797h-2.19c-.524 0-.968.382-1.05.9l-1.12 7.106z"/>
                                        </svg>
                                    </div>
                                    <span class="method-name">PayPal</span>
                                    <span class="method-desc">Fast transfers</span>
                                </div>
                            </label>
                            <label class="payout-method-option @(settings.PayoutMethod == "Bank Transfer" ? "selected" : "")">
                                <input type="radio" name="PayoutMethod" value="Bank Transfer" @(settings.PayoutMethod == "Bank Transfer" ? "checked" : "") />
                                <div class="method-card">
                                    <div class="method-icon bank">
                                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                                             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                            <rect x="1" y="4" width="22" height="16" rx="2" ry="2"/>
                                            <line x1="1" y1="10" x2="23" y2="10"/>
                                        </svg>
                                    </div>
                                    <span class="method-name">Bank Transfer</span>
                                    <span class="method-desc">Direct deposit</span>
                                </div>
                            </label>
                            <label class="payout-method-option @(settings.PayoutMethod == "Stripe" ? "selected" : "")">
                                <input type="radio" name="PayoutMethod" value="Stripe" @(settings.PayoutMethod == "Stripe" ? "checked" : "") />
                                <div class="method-card">
                                    <div class="method-icon stripe">
                                        <svg viewBox="0 0 24 24" fill="currentColor">
                                            <path d="M13.976 9.15c-2.172-.806-3.356-1.426-3.356-2.409 0-.831.683-1.305 1.901-1.305 2.227 0 4.515.858 6.09 1.631l.89-5.494C18.252.975 15.697 0 12.165 0 9.667 0 7.589.654 6.104 1.872 4.56 3.147 3.757 4.992 3.757 7.218c0 4.039 2.467 5.76 6.476 7.219 2.585.92 3.445 1.574 3.445 2.583 0 .98-.84 1.545-2.354 1.545-1.875 0-4.965-.921-6.99-2.109l-.9 5.555C5.175 22.99 8.385 24 11.714 24c2.641 0 4.843-.624 6.328-1.813 1.664-1.305 2.525-3.236 2.525-5.732 0-4.128-2.524-5.851-6.591-7.305z"/>
                                        </svg>
                                    </div>
                                    <span class="method-name">Stripe</span>
                                    <span class="method-desc">Connect account</span>
                                </div>
                            </label>
                        </div>
                    </div>

                    <div class="payout-details-form" id="paypalDetails">
                        <div class="form-group">
                            <label class="form-label" for="paypalEmail">PayPal Email</label>
                            <input type="email" id="paypalEmail" name="PaypalEmail" class="form-input" value="@settings.PaypalEmail" placeholder="your@email.com" />
                        </div>
                    </div>

                    <div class="payout-details-form hidden" id="bankDetails">
                        <div class="form-row-2">
                            <div class="form-group">
                                <label class="form-label" for="accountName">Account Holder Name</label>
                                <input type="text" id="accountName" name="BankAccountName" class="form-input" placeholder="Full legal name" />
                            </div>
                            <div class="form-group">
                                <label class="form-label" for="accountNumber">Account Number</label>
                                <input type="text" id="accountNumber" name="BankAccountNumber" class="form-input" placeholder="Account number" />
                            </div>
                        </div>
                        <div class="form-group">
                            <label class="form-label" for="routingNumber">Routing Number</label>
                            <input type="text" id="routingNumber" name="BankRoutingNumber" class="form-input" placeholder="9 digit routing number" />
                        </div>
                    </div>

                    <div class="payout-schedule-info">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="12" cy="12" r="10"/>
                            <line x1="12" y1="16" x2="12" y2="12"/>
                            <line x1="12" y1="8" x2="12.01" y2="8"/>
                        </svg>
                        <div>
                            <strong>Payout Schedule:</strong> Earnings are held for 7 days after purchase to allow for refunds. You can request payouts anytime once the balance is available. Minimum payout amount is $50.
                        </div>
                    </div>

                    <div class="form-actions">
                        <button type="submit" class="btn btn-primary">Save Payout Settings</button>
                    </div>
                </form>
            </section>

            @* Notifications Section *@
            <section id="notifications" class="settings-section card">
                <div class="settings-section-header">
                    <h2>Notification Preferences</h2>
                    <p>Choose what notifications you want to receive.</p>
                </div>
                <form class="settings-form" asp-action="UpdateNotifications" method="post">
                    <div class="notification-settings">
                        <label class="notification-toggle">
                            <div class="toggle-info">
                                <span class="toggle-title">Email Notifications</span>
                                <span class="toggle-desc">Receive important updates and announcements via email.</span>
                            </div>
                            <div class="toggle-switch">
                                <input type="checkbox" name="EmailNotifications" @(settings.EmailNotifications ? "checked" : "") />
                                <span class="toggle-slider"></span>
                            </div>
                        </label>

                        <label class="notification-toggle">
                            <div class="toggle-info">
                                <span class="toggle-title">Order Notifications</span>
                                <span class="toggle-desc">Get notified when someone purchases your product.</span>
                            </div>
                            <div class="toggle-switch">
                                <input type="checkbox" name="OrderNotifications" @(settings.OrderNotifications ? "checked" : "") />
                                <span class="toggle-slider"></span>
                            </div>
                        </label>

                        <label class="notification-toggle">
                            <div class="toggle-info">
                                <span class="toggle-title">Review Notifications</span>
                                <span class="toggle-desc">Get notified when someone leaves a review on your product.</span>
                            </div>
                            <div class="toggle-switch">
                                <input type="checkbox" name="ReviewNotifications" @(settings.ReviewNotifications ? "checked" : "") />
                                <span class="toggle-slider"></span>
                            </div>
                        </label>

                        <label class="notification-toggle">
                            <div class="toggle-info">
                                <span class="toggle-title">Weekly Summary</span>
                                <span class="toggle-desc">Receive a weekly summary of your store performance.</span>
                            </div>
                            <div class="toggle-switch">
                                <input type="checkbox" name="WeeklySummary" checked />
                                <span class="toggle-slider"></span>
                            </div>
                        </label>

                        <label class="notification-toggle">
                            <div class="toggle-info">
                                <span class="toggle-title">Marketing Emails</span>
                                <span class="toggle-desc">Tips, promotions, and opportunities to grow your store.</span>
                            </div>
                            <div class="toggle-switch">
                                <input type="checkbox" name="MarketingEmails" />
                                <span class="toggle-slider"></span>
                            </div>
                        </label>
                    </div>

                    <div class="form-actions">
                        <button type="submit" class="btn btn-primary">Save Preferences</button>
                    </div>
                </form>
            </section>

            @* API Access Section *@
            <section id="api-access" class="settings-section card">
                <div class="settings-section-header">
                    <h2>API Access</h2>
                    <p>Manage API keys for integrating with external tools.</p>
                </div>
                <div class="api-key-section">
                    <div class="api-key-display">
                        <label class="form-label">Your API Key</label>
                        <div class="api-key-input">
                            <input type="password" class="form-input" value="sk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxx" readonly id="apiKeyInput" />
                            <button type="button" class="btn btn-ghost btn-icon" onclick="toggleApiKey()" title="Show/Hide">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                                     stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                                    <circle cx="12" cy="12" r="3"/>
                                </svg>
                            </button>
                            <button type="button" class="btn btn-ghost btn-icon" onclick="copyApiKey()" title="Copy">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                                     stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
                                    <path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/>
                                </svg>
                            </button>
                        </div>
                        <span class="form-hint">Keep this key secret. Do not share it publicly.</span>
                    </div>

                    <div class="api-actions">
                        <button type="button" class="btn btn-secondary">Regenerate Key</button>
                        <a href="#" class="btn btn-ghost">View API Documentation</a>
                    </div>
                </div>
            </section>

            @* Danger Zone *@
            <section class="settings-section card danger-zone">
                <div class="settings-section-header">
                    <h2>Danger Zone</h2>
                    <p>Irreversible actions for your seller account.</p>
                </div>
                <div class="danger-actions">
                    <div class="danger-item">
                        <div class="danger-info">
                            <span class="danger-title">Pause Seller Account</span>
                            <span class="danger-desc">Temporarily hide all your products from the marketplace. You can reactivate anytime.</span>
                        </div>
                        <button type="button" class="btn btn-secondary">Pause Account</button>
                    </div>
                    <div class="danger-item">
                        <div class="danger-info">
                            <span class="danger-title">Delete Seller Account</span>
                            <span class="danger-desc">Permanently delete your seller account and all products. This cannot be undone.</span>
                        </div>
                        <button type="button" class="btn btn-danger">Delete Account</button>
                    </div>
                </div>
            </section>
        </div>
    </div>
</div>
