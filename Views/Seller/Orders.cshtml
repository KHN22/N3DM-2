@model List<Marketplace.Models.SellerOrderRow>
@{
    ViewData["Title"] = "Orders";
    ViewData["SellerPage"] = "Orders";
    Layout = "_SellerLayout";

    // Mock data for static preview
    var orders = Model ?? new List<Marketplace.Models.SellerOrderRow>
    {
        new() { OrderId = "ORD-7842", ProductTitle = "Cyberpunk City Pack", BuyerName = "John Doe", BuyerEmail = "john.doe@email.com", Amount = 49.99m, SellerEarnings = 42.49m, OrderDate = DateTime.Now.AddDays(-2), Status = "Completed" },
        new() { OrderId = "ORD-7841", ProductTitle = "Medieval Castle Kit", BuyerName = "Sarah Mitchell", BuyerEmail = "sarah.m@company.io", Amount = 79.00m, SellerEarnings = 67.15m, OrderDate = DateTime.Now.AddDays(-3), Status = "Completed" },
        new() { OrderId = "ORD-7840", ProductTitle = "Sci-Fi Vehicle Bundle", BuyerName = "Mark Wilson", BuyerEmail = "mark.wilson@dev.co", Amount = 129.00m, SellerEarnings = 109.65m, OrderDate = DateTime.Now.AddDays(-4), Status = "Pending" },
        new() { OrderId = "ORD-7839", ProductTitle = "Nature Environment", BuyerName = "Emma Johnson", BuyerEmail = "emma.j@studio.net", Amount = 34.99m, SellerEarnings = 29.74m, OrderDate = DateTime.Now.AddDays(-5), Status = "Completed" },
        new() { OrderId = "ORD-7838", ProductTitle = "Low Poly Animals Pack", BuyerName = "Alex Chen", BuyerEmail = "alex.c@design.co", Amount = 24.99m, SellerEarnings = 21.24m, OrderDate = DateTime.Now.AddDays(-6), Status = "Completed" },
        new() { OrderId = "ORD-7837", ProductTitle = "Cyberpunk City Pack", BuyerName = "Lisa Park", BuyerEmail = "lisa.p@gmail.com", Amount = 49.99m, SellerEarnings = 42.49m, OrderDate = DateTime.Now.AddDays(-7), Status = "Refunded" },
        new() { OrderId = "ORD-7836", ProductTitle = "Medieval Castle Kit", BuyerName = "David Brown", BuyerEmail = "david.b@agency.net", Amount = 79.00m, SellerEarnings = 67.15m, OrderDate = DateTime.Now.AddDays(-8), Status = "Disputed" },
        new() { OrderId = "ORD-7835", ProductTitle = "Sci-Fi Vehicle Bundle", BuyerName = "Rachel Green", BuyerEmail = "rachel.g@studio.io", Amount = 129.00m, SellerEarnings = 109.65m, OrderDate = DateTime.Now.AddDays(-10), Status = "Completed" }
    };
}

<div class="seller-orders-page">
    @* ── Page Header ── *@
    <div class="page-header-flex">
        <div>
            <h1>Orders</h1>
            <p class="page-desc">Track and manage orders from your customers.</p>
        </div>
        <div class="header-actions">
            <button class="btn btn-secondary">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/>
                    <polyline points="7 10 12 15 17 10"/>
                    <line x1="12" y1="15" x2="12" y2="3"/>
                </svg>
                Export CSV
            </button>
        </div>
    </div>

    @* ── Order Stats ── *@
    <div class="stats-grid orders-stats">
        <div class="stat-card mini">
            <div class="stat-data">
                <span class="stat-label">Total Orders</span>
                <span class="stat-value">@orders.Count</span>
            </div>
        </div>
        <div class="stat-card mini">
            <div class="stat-data">
                <span class="stat-label">Completed</span>
                <span class="stat-value text-success">@orders.Count(o => o.Status == "Completed")</span>
            </div>
        </div>
        <div class="stat-card mini">
            <div class="stat-data">
                <span class="stat-label">Pending</span>
                <span class="stat-value text-warning">@orders.Count(o => o.Status == "Pending")</span>
            </div>
        </div>
        <div class="stat-card mini">
            <div class="stat-data">
                <span class="stat-label">Issues</span>
                <span class="stat-value text-danger">@orders.Count(o => o.Status == "Refunded" || o.Status == "Disputed")</span>
            </div>
        </div>
    </div>

    @* ── Filters / Search ── *@
    <div class="orders-toolbar">
        <div class="search-box">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                 stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
            </svg>
            <input type="text" class="form-input" placeholder="Search by order ID, product, or buyer..." />
        </div>

        <div class="filter-group">
            <select class="form-select">
                <option value="">All Status</option>
                <option value="completed">Completed</option>
                <option value="pending">Pending</option>
                <option value="refunded">Refunded</option>
                <option value="disputed">Disputed</option>
            </select>

            <select class="form-select">
                <option value="">All Time</option>
                <option value="today">Today</option>
                <option value="week">This Week</option>
                <option value="month">This Month</option>
                <option value="quarter">Last 3 Months</option>
            </select>
        </div>
    </div>

    @* ── Orders Table ── *@
    <div class="card">
        <div class="table-wrapper">
            <table class="data-table orders-table">
                <thead>
                    <tr>
                        <th>Order ID</th>
                        <th>Product</th>
                        <th>Buyer</th>
                        <th>Amount</th>
                        <th>Your Earnings</th>
                        <th>Date</th>
                        <th>Status</th>
                        <th class="col-actions">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var order in orders)
                    {
                        <tr>
                            <td class="order-id">#@order.OrderId</td>
                            <td>
                                <div class="product-cell">
                                    <div class="product-thumb-sm">
                                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                                             stroke="currentColor" stroke-width="1.5">
                                            <path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/>
                                        </svg>
                                    </div>
                                    @order.ProductTitle
                                </div>
                            </td>
                            <td>
                                <div class="buyer-cell">
                                    <span class="buyer-name">@order.BuyerName</span>
                                    <span class="buyer-email">@order.BuyerEmail</span>
                                </div>
                            </td>
                            <td class="amount">$@order.Amount.ToString("N2")</td>
                            <td class="earnings">$@order.SellerEarnings.ToString("N2")</td>
                            <td>@order.OrderDate.ToString("MMM dd, yyyy")</td>
                            <td>
                                @{
                                    var statusClass = order.Status switch
                                    {
                                        "Completed" => "badge-success",
                                        "Pending" => "badge-warning",
                                        "Refunded" => "badge-neutral",
                                        "Disputed" => "badge-danger",
                                        _ => "badge-neutral"
                                    };
                                }
                                <span class="badge @statusClass">@order.Status</span>
                            </td>
                            <td class="col-actions">
                                <div class="action-buttons">
                                    <button class="btn btn-ghost btn-icon" title="View Details">
                                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                                             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                                            <circle cx="12" cy="12" r="3"/>
                                        </svg>
                                    </button>
                                    <button class="btn btn-ghost btn-icon" title="Contact Buyer">
                                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                                             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                                            <polyline points="22,6 12,13 2,6"/>
                                        </svg>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @* ── Pagination ── *@
    <div class="pagination-bar">
        <span class="pagination-info">Showing 1-8 of 8 orders</span>
        <div class="pagination-controls">
            <button class="btn btn-ghost btn-sm" disabled>
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="15 18 9 12 15 6"/>
                </svg>
                Previous
            </button>
            <div class="page-numbers">
                <button class="page-num active">1</button>
            </div>
            <button class="btn btn-ghost btn-sm" disabled>
                Next
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="9 18 15 12 9 6"/>
                </svg>
            </button>
        </div>
    </div>
</div>
